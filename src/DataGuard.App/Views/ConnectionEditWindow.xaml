<Window x:Class="DataGuard.App.Views.ConnectionEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="연결 추가" Height="400" Width="440"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize">
    <Grid Margin="16">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="110" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Grid.Column="0" Text="이름" VerticalAlignment="Center" Margin="0,6" />
        <TextBox   Grid.Row="0" Grid.Column="1" x:Name="NameBox" Margin="0,6" />

        <TextBlock Grid.Row="1" Grid.Column="0" Text="DB 종류" VerticalAlignment="Center" Margin="0,6" />
        <ComboBox  Grid.Row="1" Grid.Column="1" x:Name="ProviderBox" Margin="0,6" />

        <TextBlock Grid.Row="2" Grid.Column="0" Text="호스트" VerticalAlignment="Center" Margin="0,6" />
        <TextBox   Grid.Row="2" Grid.Column="1" x:Name="HostBox" Margin="0,6" />

        <TextBlock Grid.Row="3" Grid.Column="0" Text="포트" VerticalAlignment="Center" Margin="0,6" />
        <TextBox   Grid.Row="3" Grid.Column="1" x:Name="PortBox" Margin="0,6"
                   ToolTip="비워두면 기본 포트(SQL Server 1433 / PostgreSQL 5432) 사용" />

        <TextBlock Grid.Row="4" Grid.Column="0" Text="데이터베이스" VerticalAlignment="Center" Margin="0,6" />
        <TextBox   Grid.Row="4" Grid.Column="1" x:Name="DatabaseBox" Margin="0,6" />

        <TextBlock Grid.Row="5" Grid.Column="0" Text="사용자" VerticalAlignment="Center" Margin="0,6" />
        <TextBox   Grid.Row="5" Grid.Column="1" x:Name="UsernameBox" Margin="0,6" />

        <TextBlock Grid.Row="6" Grid.Column="0" Text="비밀번호" VerticalAlignment="Center" Margin="0,6" />
        <PasswordBox Grid.Row="6" Grid.Column="1" x:Name="PasswordBox" Margin="0,6" />

        <TextBlock Grid.Row="7" Grid.ColumnSpan="2" x:Name="HintText" TextWrapping="Wrap" Foreground="Gray"
                   Margin="0,8" VerticalAlignment="Bottom"
                   Text="비밀번호는 Windows 자격 증명 저장소(DPAPI)에 암호화 저장됩니다. 읽기 전용 계정 권장." />

        <StackPanel Grid.Row="8" Grid.ColumnSpan="2" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="0,8,0,0">
            <Button Content="저장" Width="80" IsDefault="True" Click="OnSave" Margin="0,0,8,0" />
            <Button Content="취소" Width="80" IsCancel="True" />
        </StackPanel>
    </Grid>
</Window>
