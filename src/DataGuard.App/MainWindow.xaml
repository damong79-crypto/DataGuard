<Window x:Class="DataGuard.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="DataGuard — DB 정합성 자동 체크" Height="560" Width="900">

    <DockPanel>
        <!-- 상단 도구 모음 -->
        <ToolBarTray DockPanel.Dock="Top">
            <ToolBar>
                <Button Content="연결 추가" Command="{Binding AddConnectionCommand}" Padding="10,2" />
                <Button Content="쿼리 추가" Command="{Binding AddQueryCommand}" Padding="10,2" />
                <Separator />
                <Button Content="지금 실행" Command="{Binding RunNowCommand}" Padding="10,2" />
            </ToolBar>
        </ToolBarTray>

        <!-- 하단 상태 표시줄 -->
        <StatusBar DockPanel.Dock="Bottom">
            <StatusBarItem Content="{Binding StatusMessage}" />
        </StatusBar>

        <!-- PRD 기능별 탭 골격 -->
        <TabControl Margin="8">
            <TabItem Header="연결">
              <DockPanel>
                <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="4">
                    <Button Content="편집" Command="{Binding EditConnectionCommand}" Padding="10,2" Margin="0,0,6,0" />
                    <Button Content="삭제" Command="{Binding DeleteConnectionCommand}" Padding="10,2" />
                </StackPanel>
                <DataGrid ItemsSource="{Binding Connections}"
                          SelectedItem="{Binding SelectedConnection}"
                          AutoGenerateColumns="False" IsReadOnly="True" Margin="4">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="이름" Binding="{Binding Name}" Width="*" />
                        <DataGridTextColumn Header="종류" Binding="{Binding Provider}" Width="120" />
                        <DataGridTextColumn Header="호스트" Binding="{Binding Host}" Width="180" />
                        <DataGridTextColumn Header="DB" Binding="{Binding Database}" Width="160" />
                    </DataGrid.Columns>
                </DataGrid>
              </DockPanel>
            </TabItem>

            <TabItem Header="체크 쿼리">
              <DockPanel>
                <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="4">
                    <Button Content="편집" Command="{Binding EditQueryCommand}" Padding="10,2" Margin="0,0,6,0" />
                    <Button Content="삭제" Command="{Binding DeleteQueryCommand}" Padding="10,2" />
                </StackPanel>
                <DataGrid ItemsSource="{Binding Queries}"
                          SelectedItem="{Binding SelectedQuery}"
                          AutoGenerateColumns="False" IsReadOnly="True" Margin="4">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="이름" Binding="{Binding Name}" Width="*" />
                        <DataGridTextColumn Header="스케줄" Binding="{Binding Schedule}" Width="120" />
                        <DataGridTextColumn Header="발송 정책" Binding="{Binding NotifyPolicy}" Width="140" />
                        <DataGridCheckBoxColumn Header="사용" Binding="{Binding IsEnabled}" Width="60" />
                    </DataGrid.Columns>
                </DataGrid>
              </DockPanel>
            </TabItem>

            <TabItem Header="이력">
              <DockPanel>
                <WrapPanel DockPanel.Dock="Top" Margin="4" VerticalAlignment="Center">
                    <TextBlock Text="쿼리" VerticalAlignment="Center" Margin="0,0,4,0" />
                    <ComboBox Width="150" ItemsSource="{Binding Queries}" DisplayMemberPath="Name"
                              SelectedItem="{Binding FilterQuery}" Margin="0,0,12,0"
                              ToolTip="비우면 전체 쿼리" />
                    <TextBlock Text="상태" VerticalAlignment="Center" Margin="0,0,4,0" />
                    <ComboBox Width="90" SelectedIndex="{Binding FilterStatusIndex}" Margin="0,0,12,0">
                        <ComboBoxItem Content="전체" />
                        <ComboBoxItem Content="정상" />
                        <ComboBoxItem Content="이상" />
                        <ComboBoxItem Content="오류" />
                    </ComboBox>
                    <TextBlock Text="기간" VerticalAlignment="Center" Margin="0,0,4,0" />
                    <ComboBox Width="120" SelectedIndex="{Binding FilterPeriodIndex}" Margin="0,0,12,0">
                        <ComboBoxItem Content="전체" />
                        <ComboBoxItem Content="최근 24시간" />
                        <ComboBoxItem Content="최근 7일" />
                        <ComboBoxItem Content="최근 30일" />
                    </ComboBox>
                    <Button Content="조회" Command="{Binding ApplyFilterCommand}" Padding="12,2" Margin="0,0,6,0" />
                    <Button Content="초기화" Command="{Binding ClearFilterCommand}" Padding="12,2" />
                </WrapPanel>
                <DataGrid ItemsSource="{Binding RecentResults}" AutoGenerateColumns="False"
                          IsReadOnly="True" Margin="4">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="쿼리" Binding="{Binding QueryName}" Width="*" />
                        <DataGridTextColumn Header="실행 시각" Binding="{Binding ExecutedAt}" Width="180" />
                        <DataGridTextColumn Header="상태" Binding="{Binding Status}" Width="100" />
                        <DataGridTextColumn Header="건수" Binding="{Binding RowCount}" Width="80" />
                        <DataGridTextColumn Header="소요(ms)" Binding="{Binding DurationMs}" Width="90" />
                    </DataGrid.Columns>
                </DataGrid>
              </DockPanel>
            </TabItem>

            <TabItem Header="설정">
                <StackPanel Margin="12">
                    <TextBlock Text="이메일 발송 설정" FontWeight="Bold" Margin="0,0,0,8" />
                    <TextBlock Text="{Binding SmtpSummary}" TextWrapping="Wrap" Margin="0,0,0,12" />
                    <Button Content="SMTP / 수신자 설정..." Command="{Binding OpenSmtpSettingsCommand}"
                            HorizontalAlignment="Left" Padding="12,4" />
                </StackPanel>
            </TabItem>
        </TabControl>
    </DockPanel>
</Window>
